{%- set home = "/pt/" if lang == "pt" else "/" -%}
<!-- NAV -->
<nav class="about-nav" id="about-nav">
    <div class="nav-inner-about">
        <a href="{{ home }}" class="logo-about">DMS<em>.</em></a>
        <div class="nav-about-links">
            <a href="#experience">{{ "Experiência" if lang == "pt" else "Experience" }}</a>
            <a href="#skills">{{ "Competências" if lang == "pt" else "Skills" }}</a>
            {% include "partials/lang-switch.njk" %}
            <a href="{{ home }}" class="home-cta">
                <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:middle"><polyline points="15 18 9 12 15 6"/></svg>
                {{ "Portfólio" if lang == "pt" else "Portfolio" }}
            </a>
        </div>
        <button class="hamburger-about" id="hbg-about" type="button" aria-label="{{ 'Abrir/fechar menu de navegação' if lang == 'pt' else 'Toggle navigation menu' }}" aria-expanded="false" aria-controls="mob-nav-about" onclick="toggleMenuAbout()">
            <span></span><span></span><span></span>
        </button>
    </div>
</nav>
<div class="mob-nav-about" id="mob-nav-about">
    <a href="#experience" onclick="closeMenuAbout()">{{ "Experiência" if lang == "pt" else "Experience" }}</a>
    <a href="#skills"     onclick="closeMenuAbout()">{{ "Competências" if lang == "pt" else "Skills" }}</a>
    <a href="{{ home }}"  onclick="closeMenuAbout()">← {{ "Portfólio" if lang == "pt" else "Portfolio" }}</a>
    {% include "partials/lang-switch.njk" %}
</div>

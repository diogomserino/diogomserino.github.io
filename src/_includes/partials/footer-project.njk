{%- set home = "/pt/" if lang == "pt" else "/" -%}
<footer>
    <div class="container footer-inner">
        <span class="footer-copy">© {{ site.year }} {{ site.author }}</span>
        <a href="{{ home }}" class="footer-back">
            <svg aria-hidden="true" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
            {{ "Voltar ao Portfólio" if lang == "pt" else "Back to Portfolio" }}
        </a>
    </div>
</footer>
